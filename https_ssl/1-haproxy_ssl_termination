global
log 127.0.0.1 local0

defaults
log global
mode http
timeout connect 5000
timeout client 50000
timeout server 50000

frontend http_front
bind :80
default_backend web_servers

frontend https_front
bind :443 ssl crt /etc/ssl/private/www.guym.tech.pem
default_backend web_servers

backend web_servers
balance roundrobin
server web-01 3.86.16.111:80 check
server web-02 13.222.214.21:80 check
